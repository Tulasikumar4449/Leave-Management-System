<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Notifications</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark px-4">
    <a class="navbar-brand text-white" href="/dashboard">Leave Portal</a>
    <div class="ms-auto">
      <a class="btn btn-outline-light btn-sm" href="/dashboard">Back</a>
    </div>
  </nav>
  <div class="content-wrapper">
    <div class="card p-4">
      <h3>Notifications</h3>
      <p class="text-muted mb-4">Recent alerts about your leave requests.</p>
      <ul class="list-group">
        <% notifications.forEach(note => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center <%= note.is_read ? '' : 'bg-light' %>">
            <span><%= note.message %></span>
            <small class="text-muted"><%= note.is_read ? 'Read' : 'Unread' %></small>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
</body>
</html>