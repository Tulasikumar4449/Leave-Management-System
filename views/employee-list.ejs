<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Employee List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div class="sidebar">
    <div class="px-4 text-white mb-4">
      <h4>Admin Panel</h4>
      <p>Manage staff and leave</p>
    </div>
    <div class="list-group list-group-flush">
      <a href="/admin/dashboard" class="list-group-item list-group-item-action bg-transparent text-white">Dashboard</a>
      <a href="/admin/employees" class="list-group-item list-group-item-action bg-transparent text-white active">Employees</a>
      <a href="/admin/requests" class="list-group-item list-group-item-action bg-transparent text-white">Leave Requests</a>
      <a href="/admin/logout" class="list-group-item list-group-item-action bg-transparent text-white">Logout</a>
    </div>
  </div>
  <div class="content-wrapper">
    <div class="container-fluid">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2>Employee List</h2>
          <p class="text-muted">View registered employee records.</p>
        </div>
      </div>
      <div class="card p-4">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Department</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% employees.forEach(emp => { %>
                <tr>
                  <td><%= emp.name %></td>
                  <td><%= emp.email %></td>
                  <td><%= emp.department %></td>
                  <td><a href="/admin/employee/<%= emp.id %>" class="btn btn-sm btn-primary">View</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>