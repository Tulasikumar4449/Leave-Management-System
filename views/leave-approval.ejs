<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leave Approval</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <script src="/js/leave.js" defer></script>
</head>
<body>
  <div class="sidebar">
    <div class="px-4 text-white mb-4">
      <h4>Admin Panel</h4>
      <p>Approve or reject leave</p>
    </div>
    <div class="list-group list-group-flush">
      <a href="/admin/dashboard" class="list-group-item list-group-item-action bg-transparent text-white">Dashboard</a>
      <a href="/admin/employees" class="list-group-item list-group-item-action bg-transparent text-white">Employees</a>
      <a href="/admin/requests" class="list-group-item list-group-item-action bg-transparent text-white active">Leave Requests</a>
      <a href="/admin/logout" class="list-group-item list-group-item-action bg-transparent text-white">Logout</a>
    </div>
  </div>
  <div class="content-wrapper">
    <div class="container-fluid">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
        <div>
          <h2 class="fw-bold">Leave Requests</h2>
          <p class="text-muted">Review all employee leave requests and take action quickly.</p>
        </div>
        <a href="/admin/dashboard" class="btn btn-outline-primary btn-glow">Back to Dashboard</a>
      </div>

      <div class="card p-4 shadow-sm mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
          <div>
            <h5 class="mb-1">Bulk Actions</h5>
            <p class="text-muted mb-0">Select multiple pending requests to approve or reject in one click.</p>
          </div>
          <div>
            <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('bulk-action-form').submit();">Apply Bulk Action</button>
          </div>
        </div>
      </div>

      <div class="card p-4 shadow-sm mb-4">
        <form id="bulk-action-form" action="/admin/requests/bulk-action" method="POST" onsubmit="return submitBulkAction();">
          <div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-start align-items-md-center">
            <div class="d-flex gap-2 align-items-center flex-wrap">
              <select id="bulk-action-select" class="form-select" name="action" required>
                <option value="approve">Approve Selected</option>
                <option value="reject">Reject Selected</option>
              </select>
              <button type="submit" class="btn btn-outline-secondary btn-sm">Apply Bulk Action</button>
            </div>
          </div>
          <div id="bulk-inputs"></div>
        </form>
      </div>

      <div class="table-card p-4">
        <div class="mb-4 row gx-3 gy-3 align-items-center">
          <div class="col-md-4">
            <p class="text-muted mb-0">Select multiple pending requests to approve or reject in one click.</p>
          </div>
        </div>
        <div class="table-responsive">
          <table class="table table-borderless table-hover align-middle">
            <thead class="table-light rounded-4">
              <tr>
                <th class="text-center"><input type="checkbox" id="select-all" onclick="document.querySelectorAll('.request-checkbox').forEach(chk => chk.checked = this.checked)"></th>
                <th>Employee</th>
                <th>Type</th>
                <th>From</th>
                <th>To</th>
                <th>Days</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
                <% requests.forEach(request => { %>
                  <tr>
                    <td class="text-center">
                      <% if (request.status === 'PENDING') { %>
                        <input class="request-checkbox form-check-input" type="checkbox" name="requestIds" value="<%= request.id %>">
                      <% } %>
                    </td>
                    <td><strong><%= request.employee_name %></strong></td>
                    <td><%= request.leave_type %></td>
                    <td><%= request.from_date.toISOString().split('T')[0] %></td>
                    <td><%= request.to_date.toISOString().split('T')[0] %></td>
                    <td><%= request.days %></td>
                    <td><%= request.reason %></td>
                    <td><span class="status-pill <%= request.status === 'PENDING' ? 'status-pending' : request.status === 'APPROVED' ? 'status-approved' : 'status-rejected' %>"><%= request.status %></span></td>
                    <td class="text-nowrap">
                      <% if (request.status === 'PENDING') { %>
                        <button type="button" class="btn btn-sm btn-success me-1 btn-glow" onclick="confirmSingleAction('<%= request.id %>', 'approve')">Approve</button>
                        <button type="button" class="btn btn-sm btn-danger btn-glow" onclick="confirmSingleAction('<%= request.id %>', 'reject')">Reject</button>
                      <% } else { %>
                        <span class="text-muted">No action</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </form>
    </div>
  </div>
</body>
</html>